{
  "name": "ecmanim",
  "version": "0.0.13",
  "description": "A JavaScript port of manim (Mathematical Animation Engine). Runs in Node (renders to MP4 via ffmpeg) and in the browser (live canvas + WebM export).",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnhenry/ecmanim.git"
  },
  "homepage": "https://github.com/johnhenry/ecmanim#readme",
  "bugs": {
    "url": "https://github.com/johnhenry/ecmanim/issues"
  },
  "author": "John Henry",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./browser-three": {
      "types": "./dist/browser-three.d.ts",
      "default": "./dist/browser-three.js"
    },
    "./authoring": {
      "types": "./dist/authoring.d.ts",
      "default": "./dist/authoring.js"
    },
    "./studio": {
      "types": "./dist/studio.d.ts",
      "default": "./dist/studio.js"
    }
  },
  "bin": {
    "ecmanim": "./dist/bin/ecmanim.js",
    "py2ts": "./dist/bin/py2ts.js"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "packages",
    "skills"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.bin.json",
    "prepare": "npm run build",
    "type-check": "tsc --noEmit",
    "test": "node --test 'test/**/*.test.ts'",
    "example": "node examples/basic.ts"
  },
  "keywords": [
    "manim",
    "animation",
    "math",
    "canvas",
    "3blue1brown",
    "bezier"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "harfbuzzjs": "^1.4.0",
    "three": "^0.185.1",
    "yoga-layout": "^3.2.1"
  },
  "dependencies": {
    "gifenc": "^1.0.3",
    "mathjax-full": "^3.2.1",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.4.1",
    "opentype.js": "^2.0.0",
    "polygon-clipping": "^0.15.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "typescript": "^6.0.3"
  }
}
